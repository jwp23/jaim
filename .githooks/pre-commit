#!/bin/sh
# SPDX-License-Identifier: GPL-3.0-or-later
# Copyright (C) 2026 Joseph Presley
#
# jaim pre-commit hook: enforce GPL-3.0-or-later compliance on
# staged changes before they land in a commit.
#
# Enable with:
#     git config core.hooksPath .githooks
#
# Bypass (rarely, only with a real reason):
#     git commit --no-verify

set -e

repo_root=$(git rev-parse --show-toplevel)
exec sh "$repo_root/scripts/check-gpl3.sh" --staged
